{
  "name": "justdevicecount",
  "version": "1.0.0",
  "description": "Real-time patron counting system using Cisco CMX WiFi analytics with PostgreSQL database",
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "axios": "^1.17.0",
    "axios-retry": "^4.5.0",
    "body-parser": "^2.2.2",
    "config": "^4.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "node-cron": "^4.2.1",
    "prisma": "^6.14.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "babel-loader": "^10.1.1",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.5.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-node-externals": "^3.0.0"
  },
  "scripts": {
    "start": "node ./bin/www",
    "dev": "pm2-dev start ecosystem.config.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop justdevicecount",
    "pm2:restart": "pm2 restart justdevicecount",
    "pm2:reload": "pm2 reload justdevicecount",
    "pm2:delete": "pm2 delete justdevicecount",
    "pm2:logs": "pm2 logs justdevicecount",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit",
    "pm2:flush": "pm2 flush justdevicecount",
    "test": "node test_comprehensive.js",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "export:data": "node scripts/export_and_purge.js",
    "export:data:dry": "node scripts/export_and_purge.js --dry-run",
    "export:initial": "node scripts/initial_export.js",
    "export:initial:dry": "node scripts/initial_export.js --dry-run"
  },
