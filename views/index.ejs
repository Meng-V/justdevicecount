<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <!-- Chart.js loaded from a self-hosted CDN-free copy bundled in public/ -->
  <!-- Fall back to unpkg only if the local copy is missing -->
  <script src="/crowdindex/chart.umd.min.js" onerror="this.onerror=null;this.src='https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js'"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      margin: 0;
      padding: 20px;
      background-color: #f0f2f5;
    }
    .container {
      max-width: 1280px;
      margin: 0 auto;
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 2px 12px rgba(0,0,0,.12);
      padding: 30px;
    }
    .header {
      text-align: center;
      margin-bottom: 28px;
      border-bottom: 3px solid #0066cc;
      padding-bottom: 18px;
    }
    .header h1 { margin: 0 0 6px; color: #0066cc; }
    .user-info {
      background: #e9ecef;
      padding: 8px 14px;
      border-radius: 5px;
      display: inline-block;
      font-size: .9em;
    }
    /* ---- stat cards ---- */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 18px;
      margin-bottom: 30px;
    }
    .stat-card {
      background: linear-gradient(135deg, #0066cc, #004999);
      color: #fff;
      padding: 22px 18px;
      border-radius: 10px;
      text-align: center;
      transition: transform .15s;
    }
    .stat-card:hover { transform: translateY(-2px); }
    .stat-card h3 { margin: 0 0 8px; font-size: 1.05em; opacity: .9; }
    .stat-value { font-size: 2.4em; font-weight: 700; line-height: 1.1; }
    .stat-subtitle { font-size: .78em; opacity: .75; margin-top: 6px; }
    .floor-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-top: 12px;
    }
    .floor-stat {
      background: rgba(255,255,255,.18);
      padding: 8px 4px;
      border-radius: 6px;
      font-size: .85em;
    }
    .floor-stat .floor-count { font-size: 1.4em; font-weight: 700; }
    /* ---- live indicator ---- */
    .live-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: #198754;
      color: #fff;
      font-size: .75em;
      padding: 3px 8px;
      border-radius: 12px;
      margin-left: 8px;
      vertical-align: middle;
    }
    .live-dot {
      width: 7px; height: 7px;
      background: #fff;
      border-radius: 50%;
      animation: blink 1.2s infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }
    /* ---- charts ---- */
    .charts-section { margin-top: 32px; }
    .chart-card {
      background: #fff;
      border: 1px solid #dee2e6;
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 24px;
    }
    .chart-card h2 { margin: 0 0 16px; font-size: 1.1em; color: #333; }
    .chart-container { position: relative; height: 280px; }
    /* ---- recent data table ---- */
    .recent-data { margin-top: 30px; }
    .recent-data h2 { color: #333; margin-bottom: 12px; }
    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: .9em;
    }
    .data-table th, .data-table td {
      padding: 10px 12px;
      text-align: left;
      border-bottom: 1px solid #dee2e6;
    }
    .data-table th { background: #0066cc; color: #fff; }
    .data-table tr:hover { background: #f8f9fa; }
    /* ---- nav ---- */
    .nav-links {
      text-align: center;
      margin: 20px 0;
      padding: 12px;
      background: #f8f9fa;
      border-radius: 6px;
    }
    .nav-links a {
      display: inline-block;
      margin: 4px 8px;
      padding: 7px 14px;
      background: #0066cc;
      color: #fff;
      text-decoration: none;
      border-radius: 4px;
      font-size: .88em;
      transition: background .2s;
    }
    .nav-links a:hover { background: #004999; }
    /* ---- error ---- */
    .error-banner {
      background: #dc3545;
      color: #fff;
      padding: 12px 16px;
      border-radius: 6px;
      margin-bottom: 20px;
    }
    /* ---- last-updated note ---- */
    #last-updated-note {
      text-align: right;
      font-size: .78em;
      color: #6c757d;
      margin-bottom: 8px;
    }
  </style>
</head>
<body>
<div class="container">
  <!-- Header -->
  <div class="header">
    <h1><%= title %> <span class="live-badge"><span class="live-dot"></span>LIVE</span></h1>
    <div class="user-info">Welcome, <strong><%= cas_displayName %></strong></div>
  </div>

  <!-- Navigation -->
  <div class="nav-links">
    <a href="/crowdindex/patronapi">Patron API</a>
    <a href="/crowdindex/recapi">Recreation API</a>
    <a href="/crowdindex/count_by_floor">Floor Count API</a>
    <a href="/crowdindex/health">Health Check</a>
  </div>

  <% if (typeof error !== 'undefined') { %>
    <div class="error-banner"><strong>Error:</strong> <%= error %></div>
  <% } %>

  <!-- Last-updated note (updated live by JS) -->
  <div id="last-updated-note">
    Last refreshed:
    <span id="last-updated-ts">
      <%- currentTimestamp
           ? new Date(currentTimestamp).toLocaleString('en-US', { timeZone: 'America/New_York', timeZoneName: 'short' })
           : 'N/A' %>
    </span>
  </div>

  <!-- Stat cards -->
  <div class="stats-grid" id="stats-grid">
    <div class="stat-card">
      <h3>Current Patrons</h3>
      <div class="stat-value" id="current-patrons"><%= currentPatrons %></div>
      <div class="stat-subtitle" id="current-ts">
        <% if (currentTimestamp) { %>
          <%= new Date(currentTimestamp).toLocaleString('en-US', { timeZone: 'America/New_York', timeZoneName: 'short' }) %>
        <% } %>
      </div>
    </div>

    <div class="stat-card">
      <h3>Peak Patrons (All Time)</h3>
      <div class="stat-value" id="peak-patrons"><%= maxPatrons %></div>
      <div class="stat-subtitle" id="peak-ts">
        <% if (maxPatronsTimestamp) { %>
          <%= new Date(maxPatronsTimestamp).toLocaleString('en-US', { timeZone: 'America/New_York', timeZoneName: 'short' }) %>
        <% } %>
      </div>
    </div>

    <div class="stat-card">
      <h3>Count by Floor</h3>
      <div class="floor-grid">
        <div class="floor-stat">
          <div>Ground</div>
          <div class="floor-count" id="floor-0"><%= currentCountByFloor[0] || 0 %></div>
        </div>
        <div class="floor-stat">
          <div>First</div>
          <div class="floor-count" id="floor-1"><%= currentCountByFloor[1] || 0 %></div>
        </div>
        <div class="floor-stat">
          <div>Second</div>
          <div class="floor-count" id="floor-2"><%= currentCountByFloor[2] || 0 %></div>
        </div>
        <div class="floor-stat">
          <div>Third</div>
          <div class="floor-count" id="floor-3"><%= currentCountByFloor[3] || 0 %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts -->
  <div class="charts-section">
    <div class="chart-card">
      <h2>Total Patrons — Last 30 Days</h2>
      <div class="chart-container">
        <canvas id="totalChart"></canvas>
      </div>
    </div>

    <div class="chart-card">
      <h2>Patrons by Floor — Last 30 Days</h2>
      <div class="chart-container">
        <canvas id="floorChart"></canvas>
      </div>
    </div>
  </div>

  <!-- Recent data table -->
  <div class="recent-data">
    <h2>Recent Records (Last 10)</h2>
    <table class="data-table" id="recent-table">
      <thead>
        <tr>
          <th>Timestamp (ET)</th>
          <th>Total Patrons</th>
          <th>Ground</th>
          <th>First</th>
          <th>Second</th>
          <th>Third</th>
        </tr>
      </thead>
      <tbody id="recent-tbody">
        <% if (recentData && recentData.length > 0) { %>
          <% recentData.forEach(function(record) { %>
            <tr>
              <td><%- new Date(record.timeStamp).toLocaleString('en-US', { timeZone: 'America/New_York', timeZoneName: 'short' }) %></td>
              <td><strong><%= record.patrons %></strong></td>
              <td><%= record.countByFloor ? record.countByFloor[0] || 0 : 0 %></td>
              <td><%= record.countByFloor ? record.countByFloor[1] || 0 : 0 %></td>
              <td><%= record.countByFloor ? record.countByFloor[2] || 0 : 0 %></td>
              <td><%= record.countByFloor ? record.countByFloor[3] || 0 : 0 %></td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="6">No recent data available.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div><!-- /.container -->

<script>
// ---------------------------------------------------------------------------
// Dashboard live-update script
// Fetches /crowdindex/patronapi and /crowdindex/count_by_floor every 5 minutes
// and updates only the DOM nodes that changed — no full-page reload.
// ---------------------------------------------------------------------------

const BASE = '/crowdindex';
let totalChart = null;
let floorChart = null;

// Helper: format an ISO timestamp string into Eastern time
function fmtET(iso) {
  if (!iso) return 'N/A';
  return new Date(iso).toLocaleString('en-US', {
    timeZone: 'America/New_York',
    timeZoneName: 'short'
  });
}

// Build / rebuild the Total Patrons line chart
function renderTotalChart(timeMap) {
  const labels = timeMap.map(d => fmtET(d.time));
  const values = timeMap.map(d => d.total);

  if (totalChart) {
    totalChart.data.labels        = labels;
    totalChart.data.datasets[0].data = values;
    totalChart.update('none');
    return;
  }

  const ctx = document.getElementById('totalChart').getContext('2d');
  totalChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label:           'Total Patrons',
        data:            values,
        borderColor:     '#0066cc',
        backgroundColor: 'rgba(0,102,204,.1)',
        borderWidth:     1.5,
        pointRadius:     0,
        fill:            true,
        tension:         0.3,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: {
          ticks: {
            maxTicksLimit: 12,
            maxRotation:   45,
            font: { size: 10 }
          }
        },
        y: { beginAtZero: true }
      }
    }
  });
}

// Build / rebuild the per-floor stacked area chart
function renderFloorChart(floorMap) {
  const labels      = floorMap.map(d => d.time);
  const floorNames  = ['Ground', 'First', 'Second', 'Third'];
  const colors      = ['#0066cc', '#20c997', '#ffc107', '#dc3545'];

  const datasets = floorNames.map((name, i) => ({
    label:           name,
    data:            floorMap.map(d => (d.countByFloor && d.countByFloor[i]) || 0),
    borderColor:     colors[i],
    backgroundColor: colors[i] + '33',
    borderWidth:     1.5,
    pointRadius:     0,
    fill:            true,
    tension:         0.3,
  }));

  if (floorChart) {
    floorChart.data.labels   = labels;
    floorChart.data.datasets.forEach((ds, i) => { ds.data = datasets[i].data; });
    floorChart.update('none');
    return;
  }

  const ctx = document.getElementById('floorChart').getContext('2d');
  floorChart = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'top', labels: { boxWidth: 12, font: { size: 11 } } }
      },
      scales: {
        x: {
          ticks: { maxTicksLimit: 12, maxRotation: 45, font: { size: 10 } }
        },
        y: { beginAtZero: true, stacked: false }
      }
    }
  });
}

// Update the recent-records table rows
function updateRecentTable(lastTen) {
  const tbody = document.getElementById('recent-tbody');
  if (!tbody || !lastTen || !lastTen.length) return;
  tbody.innerHTML = lastTen.map(r => {
    const cbf = r.countByFloor || [];
    return `<tr>
      <td>${fmtET(r.time)}</td>
      <td><strong>${r.patrons}</strong></td>
      <td>${cbf[0] || 0}</td>
      <td>${cbf[1] || 0}</td>
      <td>${cbf[2] || 0}</td>
      <td>${cbf[3] || 0}</td>
    </tr>`;
  }).join('');
}

// Refresh stat-card numbers without a page reload
function updateStatCards(data) {
  const setIfChanged = (id, val) => {
    const el = document.getElementById(id);
    if (el && el.textContent !== String(val)) el.textContent = val;
  };

  setIfChanged('current-patrons', data.patrons);

  const el = document.getElementById('current-ts');
  if (el && data.lastTen && data.lastTen[0]) {
    el.textContent = fmtET(data.lastTen[0].time);
  }

  if (data.lastTen && data.lastTen[0] && data.lastTen[0].countByFloor) {
    data.lastTen[0].countByFloor.forEach((cnt, i) => setIfChanged(`floor-${i}`, cnt));
  }

  if (data.findMax) {
    setIfChanged('peak-patrons', data.findMax.patrons);
    const peakTs = document.getElementById('peak-ts');
    if (peakTs) peakTs.textContent = fmtET(data.findMax.time);
  }

  const lun = document.getElementById('last-updated-ts');
  if (lun && data.lastTen && data.lastTen[0]) {
    lun.textContent = fmtET(data.lastTen[0].time);
  }
}

// Main refresh function — called on load and every 5 minutes
async function refresh() {
  try {
    const [patronRes, floorRes] = await Promise.all([
      fetch(`${BASE}/patronapi`),
      fetch(`${BASE}/count_by_floor`)
    ]);

    if (patronRes.ok) {
      const patron = await patronRes.json();
      if (patron.success) {
        updateStatCards(patron.data);
        renderTotalChart(patron.data.timeMap || []);
        updateRecentTable(patron.data.lastTen || []);
      }
    }

    if (floorRes.ok) {
      const floor = await floorRes.json();
      if (floor.floorMap) renderFloorChart(floor.floorMap);
    }
  } catch (err) {
    console.warn('Dashboard refresh error:', err);
  }
}

// Initial render on page load
refresh();

// Live update every 5 minutes (no full-page reload)
setInterval(refresh, 5 * 60 * 1000);
</script>
</body>
</html>
