# JustDeviceCount Environment Configuration
# Copy this file to .env and update with your values

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/justdevicecount"

# Application Settings
NODE_ENV="development"
PORT=3012
TZ="America/New_York"

# Production Server Configuration
PRODUCTION_HOSTNAME="your-production-server.edu"

# SSL Certificate Paths (optional - defaults to security/ directory)
HTTPS_CERT_PATH="./security/cert.pem"
HTTPS_KEY_PATH="./security/cert.key"

# Production SSL Certificate Paths (for production environment)
PROD_CERT_PATH="/etc/pki/tls/certs/your-production-server.edu-cert.pem"
PROD_KEY_PATH="/etc/pki/tls/certs/your-production-server.edu-privkey.pem"

# Optional: Debug settings
# DEBUG="*"

# Cisco CMX API credentials
# Base64-encode your "username:password" string:
#   echo -n "user:pass" | base64
# Then set: CMX_AUTH="Basic <result>"
CMX_AUTH="Basic YOUR_BASE64_ENCODED_CREDENTIALS_HERE"

# Test User Configuration (for development dashboard)
TEST_USER_ID="testuser"
TEST_USER_NAME="Test Developer"

# Admin Analytics Dashboard (/crowdindex/admin)
# Generate a token with:  node -e "require('crypto').randomBytes(32).toString('base64url') |> console.log"
# or:                     node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Share the full URL with colleagues — no login required:
#   https://your-server/crowdindex/admin?t=<ADMIN_TOKEN>
# Leave ADMIN_TOKEN unset to disable the gate (open access — dev only).
ADMIN_TOKEN="replace-with-output-of-crypto-randomBytes-32-base64url"

# Production Settings (uncomment for production)
# NODE_ENV="production"
# DATABASE_URL="postgresql://prod_user:prod_pass@prod_host:5432/justdevicecount_prod"
# PRODUCTION_HOSTNAME="your-production-server.edu"
