#!/usr/bin/env node

// sudo lsof -i:3012 ## see a specific port such as 3012 ##
// sudo kill PID


require('dotenv').config();

// Set timezone to New York for all logging
process.env.TZ = 'America/New_York';

/**
 * Module dependencies.
 */

const config = require("config");
const https = require("https");
const fs = require("fs");
const app = require("../app");

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  const port = parseInt(val, 10);

  if (Number.isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Get port from environment and store in Express.
 */

// Server detection logic
// Use environment variables to determine server type
console.log("process.env.HOSTNAME: " + process.env.HOSTNAME);
console.log("process.env.NODE_ENV: " + process.env.NODE_ENV);

// Detect server environment based on NODE_ENV and hostname
const productionHostname = process.env.PRODUCTION_HOSTNAME
const isProduction = process.env.NODE_ENV === "production" || 
                    process.env.HOSTNAME === productionHostname;
const isLocalhost = !process.env.HOSTNAME || 
                   process.env.HOSTNAME === "localhost" || 
                   process.env.HOSTNAME === "127.0.0.1" ||
                   process.env.NODE_ENV === "development";

global.onServer = isProduction;
global.isLocalhost = isLocalhost;

console.log(`Environment: ${isProduction ? 'Production' : (isLocalhost ? 'Localhost' : 'Unknown')}`);
console.log(`On Server? : ${global.onServer}`);

const PORT = normalizePort(process.env.PORT || config.get("app.port") || 3012);

const basePath = "/crowdindex";

// Start server based on environment
if (isLocalhost) {
  // Local development: Use HTTP (no SSL)
  const http = require("http");
  
  http.createServer(app).listen(PORT, () => {
    console.log(`\n${'='.repeat(60)}`);
    console.log(`🚀 LOCAL DEVELOPMENT SERVER STARTED`);
    console.log(`${'='.repeat(60)}`);
    console.log(`Environment: Development`);
    console.log(`Port: ${PORT}`);
    console.log(`\n📊 Dashboard:`);
    console.log(`   http://localhost:${PORT}${basePath}/`);
    console.log(`\n📡 API Endpoints:`);
    console.log(`   Patron API:     http://localhost:${PORT}${basePath}/patronapi`);
    console.log(`   Recreation API: http://localhost:${PORT}${basePath}/recapi`);
    console.log(`   Floor Count:    http://localhost:${PORT}${basePath}/count_by_floor`);
    console.log(`${'='.repeat(60)}\n`);
  });
} else {
  // Production: Use HTTPS with SSL certificates
  const prodCertPath = process.env.PROD_CERT_PATH;
  const prodKeyPath = process.env.PROD_KEY_PATH;

  if (!prodCertPath || !prodKeyPath) {
    console.error('❌ ERROR: SSL certificate paths not configured!');
    console.error('   Set PROD_CERT_PATH and PROD_KEY_PATH in .env file');
    process.exit(1);
  }

  https
    .createServer(
      {
        key: fs.readFileSync(prodKeyPath),
        cert: fs.readFileSync(prodCertPath),
      },
      app
    )
    .listen(PORT, () => {
      console.log(`\n${'='.repeat(60)}`);
      console.log(`🔒 PRODUCTION HTTPS SERVER STARTED`);
      console.log(`${'='.repeat(60)}`);
      console.log(`Environment: Production`);
      console.log(`Hostname: ${productionHostname}`);
      console.log(`Port: ${PORT}`);
      console.log(`SSL: Enabled`);
      console.log(`\n📊 Dashboard:`);
      console.log(`   https://${productionHostname}:${PORT}${basePath}/`);
      console.log(`\n📡 API Endpoints:`);
      console.log(`   Patron API:     https://${productionHostname}:${PORT}${basePath}/patronapi`);
      console.log(`   Recreation API: https://${productionHostname}:${PORT}${basePath}/recapi`);
      console.log(`   Floor Count:    https://${productionHostname}:${PORT}${basePath}/count_by_floor`);
      console.log(`${'='.repeat(60)}\n`);
    });
}
